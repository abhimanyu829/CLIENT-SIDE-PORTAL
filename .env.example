# ─────────────────────────────────────────────────────────────────────────────
# SaaS Platform — Environment Variables Template
# Copy this file to .env and fill in all values before running the application.
# NEVER commit the filled-in .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://saasuser:yourpassword@localhost:5432/saasdb
POSTGRES_DB=saasdb
POSTGRES_USER=saasuser
POSTGRES_PASSWORD=yourpassword

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redispassword@localhost:6379
REDIS_PASSWORD=redispassword

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-min-32-chars-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=NexusAI <onboarding@resend.dev>

# ── Cloudflare R2 / AWS S3 (Storage) ─────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=saas-invoices
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-bucket.r2.dev

# ── Pusher (Real-time) ────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Upstash Redis (Rate Limiting — can reuse main Redis or use Upstash) ───────
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ── GST / Invoice ─────────────────────────────────────────────────────────────
COMPANY_NAME="Your Company Pvt Ltd"
COMPANY_GST_NUMBER=
COMPANY_PAN=
COMPANY_ADDRESS="Your address, City, State - 000000"
COMPANY_EMAIL=billing@yourdomain.com
